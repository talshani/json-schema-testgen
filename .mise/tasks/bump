#!/usr/bin/env bash
# mise description="Bump version, create git tag, and push it"
set -euo pipefail

VERSION="${1:-}"

if [[ -z "$VERSION" ]]; then
  echo "Usage: mise run bump <version>" >&2
  echo "  e.g. mise run bump 1.0.0" >&2
  exit 1
fi

if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "Error: version must be semver (e.g. 1.0.0)" >&2
  exit 1
fi

TAG="v${VERSION}"

if git rev-parse "$TAG" >/dev/null 2>&1; then
  echo "Error: tag $TAG already exists" >&2
  exit 1
fi

git tag "$TAG"
git push origin "$TAG"

echo "Tagged and pushed $TAG"
