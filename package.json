{
  "name": "json-schema-testgen",
  "version": "0.1.1",
  "description": "Generate test files from the official JSON-Schema-Test-Suite",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "json-schema-testgen": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build-data": "bun src/build-test-data.ts",
    "generate": "bun src/cli.ts",
    "build": "bun run build-data && bunx tsc -p tsconfig.build.json",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "license": "MIT"
}
